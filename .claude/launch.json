{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "flutter-web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port=5000", "--dart-define-from-file=.env.json"],
      "port": 5000
    },
    {
      "name": "flutter-web-demo",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port=5001"],
      "port": 5001
    },
    {
      "name": "flutter-web-release",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "-l", "5002", "build/web"],
      "port": 5002
    }
  ]
}
